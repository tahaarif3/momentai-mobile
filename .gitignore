# Dependencies
node_modules/

# Environment / secrets (keep the example)
.env
.env.*
!.env.example

# Vite build output (Capacitor webDir)
dist/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS junk
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# Editors / IDEs
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# Test / coverage / local tooling
coverage/
.nyc_output/
.turbo/
.cache/
.temp/
.tmp/

# Maestro local runs (keep committed flows under maestro/)
.maestro/

# Android local caches (project .gitignore also covers most of this)
android/.gradle/
android/**/build/
android/local.properties
android/captures/
android/.cxx/
*.apk
*.aab
*.ap_
*.dex

# iOS local caches / CocoaPods (project .gitignore also covers most of this)
ios/App/Pods/
ios/App/build/
ios/App/output/
ios/DerivedData/
ios/**/*.xcuserstate
ios/**/xcuserdata/
*.xcuserdata
*.xcuserstate

# Capacitor synced web assets are regenerated by `npx cap sync`
# (also listed in android/.gitignore and ios/.gitignore)
android/app/src/main/assets/public/
ios/App/App/public/

# Misc
*.pem
*.p12
*.keystore
!debug.keystore
.vercel/
.netlify/
