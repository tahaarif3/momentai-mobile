# API (Phase 0 MomentAi backend — production has compatibility + progressToken)
VITE_API_BASE=https://momentai.dev

# Supabase — optional if /api/auth/config is reachable; otherwise set explicitly
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Deep link / auth redirect (must be allowlisted in Supabase Auth URL config)
# Prefer Universal/App Links; custom scheme is the fallback.
VITE_AUTH_REDIRECT_URL=momentai://auth/callback

# App version compared against GET /api/mobile/compatibility
VITE_APP_VERSION=0.1.0

# Analytics / crash (never send images, prompts, tokens, or emails)
VITE_GA4_MEASUREMENT_ID=
VITE_SENTRY_DSN=

# RevenueCat (Phase 6 — Stripe checkout is web-only)
VITE_REVENUECAT_IOS_API_KEY=
VITE_REVENUECAT_ANDROID_API_KEY=
VITE_REVENUECAT_ENTITLEMENT_ID=premium
