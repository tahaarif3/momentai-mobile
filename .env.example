# Absolute API origin consumed by the Capacitor WebView (no trailing slash)
VITE_API_BASE=https://momentai.dev

# Supabase (anon key only — never service role)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional analytics / crash reporting (Phase 5+)
VITE_GA4_MEASUREMENT_ID=
VITE_SENTRY_DSN=

# App version string compared against GET /api/mobile/compatibility
VITE_APP_VERSION=0.1.0
