{
  "name": "momentai-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "MomentAI Capacitor + Vite mobile client (iOS / Android)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "test:unit": "node --test src/**/*.test.js",
    "test:maestro": "maestro test maestro/"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/app": "^7.0.2",
    "@capacitor/browser": "^7.0.2",
    "@capacitor/camera": "^7.0.2",
    "@capacitor/clipboard": "^7.0.4",
    "@capacitor/core": "^7.4.2",
    "@capacitor/filesystem": "^7.1.4",
    "@capacitor/ios": "^7.4.2",
    "@capacitor/preferences": "^7.0.2",
    "@capacitor/share": "^7.0.2",
    "@capacitor/status-bar": "^7.0.2",
    "@revenuecat/purchases-capacitor": "^11.3.2",
    "@sentry/browser": "^10.66.0",
    "@supabase/supabase-js": "^2.50.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "vite": "^7.0.4"
  },
  "engines": {
    "node": ">=20"
  }
}
